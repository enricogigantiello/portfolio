<!-- Hero Header -->
<section class="cv-header text-white py-5">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-auto">
        <div class="profile-photo-placeholder rounded-circle d-flex align-items-center justify-content-center overflow-hidden">
          <%= image_tag "profile.png", class: "rounded-circle profile-photo", alt: @profile.full_name %>
        </div>
      </div>
      <div class="col">
        <h1 class="display-4 fw-bold mb-1"><%= @profile.full_name.upcase %></h1>
        <h2 class="h4 fw-light text-white-50"><%= @profile.title %></h2>
      </div>
    </div>

    <!-- Contact Bar -->
    <div class="row mt-4">
      <div class="col">
        <div class="d-flex flex-wrap gap-4 contact-bar">
          <a href="tel:<%= @profile.phone %>" class="text-white text-decoration-none"><i class="bi bi-telephone-fill me-1"></i> <%= @profile.phone %></a>
          <a href="mailto:<%= @profile.email %>" class="text-white text-decoration-none"><i class="bi bi-envelope-fill me-1"></i> <%= @profile.email %></a>
          <a href="<%= @profile.linkedin_url %>" target="_blank" rel="noopener noreferrer" class="text-white text-decoration-none"><i class="bi bi-linkedin me-1"></i> <%= @profile.linkedin_handle %></a>
          <span><i class="bi bi-geo-alt-fill me-1"></i> <%= @profile.location %></span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Professional Summary & Tech Stack -->
<section class="py-5">
  <div class="container">
    <div class="row g-5">
      <!-- Left Column: Summary + Achievements -->
      <div class="col-lg-7">
        <div class="mb-5">
          <h3 class="section-title"><%= t("home.sections.summary") %></h3>
          <hr class="section-divider">
          <p class="text-muted"><%= @profile.summary_p1 %></p>
          <p class="text-muted"><%= @profile.summary_p2 %></p>
          <p class="text-muted"><%= @profile.summary_p3 %></p>
        </div>

        <div>
          <h3 class="section-title"><%= t("home.sections.achievements") %></h3>
          <hr class="section-divider">
          <ul class="achievements-list">
            <% @profile.profile_achievements.each do |achievement| %>
              <li><%= achievement.description %></li>
            <% end %>
          </ul>
        </div>
      </div>

      <!-- Right Column: Tech Stack -->
      <div class="col-lg-5">
        <h3 class="section-title"><%= t("home.sections.tech_stack") %></h3>
        <hr class="section-divider">
        <p class="text-muted small mb-3"><%= t("home.tech_stack.description") %></p>

        <div class="tech-stack">
          <% @tech_categories.each do |category| %>
            <div class="mb-3">
              <h6 class="text-uppercase fw-bold small text-muted mb-2">
                <i class="<%= tech_category_icon(category) %> me-1"></i> <%= category.name %>
              </h6>
              <div class="d-flex flex-wrap gap-2">
                <% category.techs.each do |tech| %>
                  <span class="badge tech-badge"><%= tech.name %></span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Experience -->
<section class="py-5 bg-light">
  <div class="container">
    <h3 class="section-title"><%= t("home.sections.experience") %></h3>
    <hr class="section-divider">

    <% @jobs.each do |job| %>
      <%= render 'shared/job_item', job: job, show_link: true %>
    <% end %>
  </div>
</section>

<!-- Education & Languages -->
<section class="py-5">
  <div class="container">
    <div class="row g-5">
      <!-- Education -->
      <div class="col-lg-7">
        <h3 class="section-title"><%= t("home.sections.education") %></h3>
        <hr class="section-divider">

        <% @educations.each do |education| %>
          <div class="mb-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap mb-1">
              <div>
                <h5 class="fw-bold mb-0"><%= education.degree %></h5>
                <span class="text-muted"><%= education.institution %></span>
              </div>
              <span class="badge bg-secondary-subtle text-secondary">
                <%= education.start_date.strftime('%Y') %> &ndash; <%= education.end_date.strftime('%Y') %>
              </span>
            </div>
            <% if education.grade.present? && education.grade_max.present? %>
              <div class="d-flex align-items-center gap-2 mt-2">
                <span class="text-muted small" style="white-space: nowrap;">
                  <%= t("home.education.grade") %>: <%= education.grade %> / <%= education.grade_max %>
                </span>
                <div class="progress flex-grow-1" style="height: 6px;">
                  <div class="progress-bar <%= education.grade_percentage >= 80 ? 'bg-success' : education.grade_percentage >= 60 ? 'bg-info' : 'bg-warning' %>"
                       role="progressbar"
                       style="width: <%= education.grade_percentage %>%"></div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <!-- Languages -->
      <div class="col-lg-5">
        <h3 class="section-title"><%= t("home.sections.languages") %></h3>
        <hr class="section-divider">

        <div class="d-flex flex-column gap-3">
          <% @languages.each do |language| %>
            <div>
              <div class="d-flex justify-content-between mb-1">
                <span class="fw-semibold"><%= language.name %></span>
                <span class="text-muted small"><%= language.level.upcase %></span>
              </div>
              <div class="progress" style="height: 6px;">
                <div class="progress-bar" role="progressbar" style="width: <%= language.level_percentage %>%"></div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
