<div class="experience-item mb-5">
  <div class="d-flex justify-content-between align-items-start flex-wrap mb-1">
    <div>
      <h5 class="fw-bold mb-0">
        <% if local_assigns.fetch(:show_link, true) %>
          <%= link_to job.title, job_path(job), class: 'text-decoration-none' %>
        <% else %>
          <%= job.title %>
        <% end %>
      </h5>
      <span class="text-primary fw-semibold">
        <% favicon = job.reference_link&.favicon %>
        <% if favicon.present? %>
          <%= image_tag favicon, class: "favicon me-1", alt: "#{job.title} favicon", style: "width: 20px; height: 20px;" %>
        <% end %>
        <%= job.company %>
      </span>
    </div>
    <span class="badge bg-secondary-subtle text-secondary">
      <%= job.start_date.strftime('%Y') %> &ndash;
      <% if job.end_date %>
        <%= job.end_date.strftime('%Y') %>
      <% else %>
        <%= t("home.experience.present") %>
      <% end %>
    </span>
  </div>

  <% if job.description.present? %>
    <p class="text-muted small mt-2 mb-3"><%= job.description %></p>
  <% end %>

  <% if job.projects.any? %>
    <p class="text-muted small mt-2 mb-3"><%= t("home.experience.selected_projects") %></p>
    <div class="ps-2 d-flex flex-column gap-3">
      <% job.projects.ordered.each do |project| %>
        <%= render 'shared/project_item', project: project, job: job, show_link: local_assigns.fetch(:show_link, true) %>
      <% end %>
    </div>
  <% end %>
</div>
