<!-- Projects Header -->
<section class="py-5 bg-light">
  <div class="container">
    <nav aria-label="Navigation breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><%= link_to "Home", localized_root_path %></li>
        <% if @job %>
          <li class="breadcrumb-item"><%= link_to "Experience", jobs_path %></li>
          <li class="breadcrumb-item"><%= link_to @job.company, job_path(@job) %></li>
          <li class="breadcrumb-item active" aria-current="page">Projects</li>
        <% else %>
          <li class="breadcrumb-item active" aria-current="page">All Projects</li>
        <% end %>
      </ol>
    </nav>

    <h1 class="display-5 fw-bold mb-2">
      <% if @job %>
        Projects at <%= @job.company %>
      <% else %>
        All Projects
      <% end %>
    </h1>
    <p class="lead text-muted">
      <% if @job %>
        Showcasing <%= @projects.count %> <%= 'project'.pluralize(@projects.count) %> delivered at <%= @job.company %>
      <% else %>
        A comprehensive portfolio of <%= @projects.count %> <%= 'project'.pluralize(@projects.count) %> across all positions
      <% end %>
    </p>
  </div>
</section>

<!-- Projects Grid -->
<section class="py-5">
  <div class="container">
    <% if @projects.any? %>
      <div class="row g-4">
        <% @projects.each do |project| %>
          <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
              <div class="card-body p-4">
                <!-- Project Header -->
                <div class="d-flex justify-content-between align-items-start flex-wrap mb-3">
                  <div class="flex-grow-1">
                    <h4 class="fw-bold mb-1">
                      <%= link_to project.title, job_project_path(project.job, project), class: "text-decoration-none" %>
                    </h4>
                    <% unless @job %>
                      <p class="text-muted small mb-0">
                        <i class="bi bi-building me-1"></i>
                        <%= link_to project.job.company, job_path(project.job), class: "text-muted text-decoration-none" %>
                      </p>
                    <% end %>
                  </div>
                  <% if project.role.present? %>
                    <span class="badge tech-badge-role ms-2"><%= project.role %></span>
                  <% end %>
                </div>

                <!-- Project Description -->
                <% if project.description.present? %>
                  <p class="text-muted mb-3"><%= truncate(project.description, length: 150) %></p>
                <% end %>

                <!-- Technologies -->
                <% if project.techs.any? %>
                  <div class="mb-3">
                    <h6 class="text-uppercase fw-bold small text-muted mb-2">
                      <i class="bi bi-stack me-1"></i> Tech Stack
                    </h6>
                    <div class="d-flex flex-wrap gap-2">
                      <% project.techs.take(6).each do |tech| %>
                        <span class="badge tech-badge"><%= tech.name %></span>
                      <% end %>
                      <% if project.techs.count > 6 %>
                        <span class="badge bg-secondary-subtle text-secondary">+<%= project.techs.count - 6 %> more</span>
                      <% end %>
                    </div>
                  </div>
                <% end %>

                <!-- Achievements Preview -->
                <% if project.project_achievements.any? %>
                  <div class="mb-3">
                    <h6 class="text-uppercase fw-bold small text-muted mb-2">
                      <i class="bi bi-trophy me-1"></i> Highlights
                    </h6>
                    <ul class="text-muted small mb-0">
                      <% project.project_achievements.ordered.take(3).each do |achievement| %>
                        <li><%= truncate(achievement.description, length: 80) %></li>
                      <% end %>
                      <% if project.project_achievements.count > 3 %>
                        <li class="text-secondary">+ <%= project.project_achievements.count - 3 %> more achievements</li>
                      <% end %>
                    </ul>
                  </div>
                <% end %>

                <!-- View Details Link -->
                <div class="mt-3 pt-3 border-top">
                  <%= link_to job_project_path(project.job, project), class: "btn btn-sm btn-outline-primary" do %>
                    View Full Details <i class="bi bi-arrow-right ms-1"></i>
                  <% end %>

                  <% if project.reference_links.any? %>
                    <span class="text-muted small ms-2">
                      <i class="bi bi-link-45deg"></i> <%= project.reference_links.count %> <%= 'link'.pluralize(project.reference_links.count) %>
                    </span>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>
        No projects available yet.
      </div>
    <% end %>
  </div>
</section>
